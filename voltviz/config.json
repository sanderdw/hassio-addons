{
  "name": "VoltViz",
  "version": "0.13.3",
  "slug": "voltviz",
  "description": "A dynamic, real-time music visualizer that transforms sound into stunning visual experiences",
  "arch": ["aarch64", "amd64"],
  "image": "ghcr.io/sanderdw/hassio-addons/ha-voltviz-{arch}",
  "url": "https://github.com/sanderdw/voltviz",
  "startup": "application",
  "boot": "auto",
  "ingress": true,
  "ingress_stream": true,
  "panel_icon": "mdi:waveform",
  "webui": "http://[HOST]:[PORT:80]",
  "init": false,
  "ports": {
    "80/tcp": 8099
  },
  "ports_description": {
    "80/tcp": "Web UI port (direct access, not needed when using Ingress)"
  },
  "options": {
    "SENDSPIN_URL": "http://d5369777-music-assistant:8927"
  },
  "schema": {
    "SENDSPIN_URL": "str?"
  }
}
